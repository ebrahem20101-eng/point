<!doctype html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>نظام مدرسة الوليد بن عمارة - V9</title>
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;700;900&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Tajawal', sans-serif; background: radial-gradient(circle at center, #1e293b 0%, #0f172a 100%); color: white; min-height: 100vh; }
    .tab-active { background: #fbbf24; color: #0f172a; font-weight: 900; box-shadow: 0 0 20px rgba(251, 191, 36, 0.4); }
    .gold-card { border: 2px solid #fbbf24; background: rgba(30, 41, 59, 0.9); box-shadow: 0 0 30px rgba(251, 191, 36, 0.2); }
    .btn-delete { background: #ef4444; color: white; padding: 2px 8px; border-radius: 6px; font-size: 12px; font-weight: bold; }
    input, select { color: white !important; }
  </style>
</head>
<body class="p-4 md:p-8">
  <header class="max-w-6xl mx-auto flex flex-col md:flex-row justify-between items-center mb-10 bg-slate-800/40 p-6 rounded-[2rem] border border-slate-700">
    <div class="text-center md:text-right">
      <h1 class="text-3xl font-black text-amber-500 italic">🏆 مدرسة الوليد بن عمارة</h1>
      <p class="text-slate-400 font-bold text-sm">نظام إدارة النقاط السحابي V9</p>
    </div>
    <nav class="flex bg-slate-900 p-1.5 rounded-2xl border border-slate-700 mt-4 md:mt-0">
      <button onclick="switchTab('display')" id="btn-display" class="tab-active px-6 py-2 rounded-xl transition-all">الشاشة</button>
      <button onclick="switchTab('control')" id="btn-control" class="px-6 py-2 rounded-xl transition-all">المعلمون</button>
      <button onclick="switchTab('admin')" id="btn-admin" class="px-6 py-2 rounded-xl transition-all">الإدارة</button>
    </nav>
  </header>
  <main class="max-w-6xl mx-auto">
    <section id="sec-display" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8"></section>
    <section id="sec-admin" class="hidden space-y-8">
      <div class="bg-amber-500/10 border border-amber-500/50 p-6 rounded-2xl">
        <h4 class="font-black mb-2 text-amber-500">☁️ رابط السحابة (Firebase)</h4>
        <input id="fb-url" type="text" placeholder="انسخ رابط Firebase هنا..." class="w-full p-3 rounded-xl bg-slate-900 border border-slate-700 mb-2">
        <button onclick="saveCloudConfig()" class="bg-amber-500 text-slate-900 px-6 py-2 rounded-xl font-bold">حفظ وربط</button>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-slate-800 p-6 rounded-3xl border border-slate-700">
          <h4 class="text-xl font-black mb-4 text-amber-500">🎓 إدارة الطلاب</h4>
          <div class="flex gap-2 mb-4">
            <input id="new-s-name" type="text" placeholder="اسم الطالب" class="flex-1 p-2 bg-slate-900 border border-slate-700 rounded-lg">
            <input id="new-s-class" type="text" placeholder="الفصل" class="w-20 p-2 bg-slate-900 border border-slate-700 rounded-lg">
            <button onclick="addStudentManual()" class="bg-emerald-600 px-4 rounded-lg font-bold">إضافة</button>
          </div>
          <button onclick="document.getElementById('up-s').click()" class="w-full bg-slate-700 p-2 rounded-lg border border-dashed border-slate-500 mb-4">رفع إكسل طلاب</button>
          <input type="file" id="up-s" class="hidden" onchange="handleS()">
          <div class="max-h-64 overflow-y-auto bg-slate-900 rounded-xl p-2 border border-slate-800">
            <table class="w-full text-right text-sm">
              <thead class="sticky top-0 bg-slate-900"><tr class="text-slate-500 border-b border-slate-800"><th>الطالب</th><th>إجراء</th></tr></thead>
              <tbody id="list-s"></tbody>
            </table>
          </div>
        </div>
        <div class="bg-slate-800 p-6 rounded-3xl border border-slate-700">
          <h4 class="text-xl font-black mb-4 text-amber-500">👨‍🏫 إدارة المعلمين</h4>
          <div class="flex gap-2 mb-4">
            <input id="new-t-name" type="text" placeholder="اسم المعلم" class="flex-1 p-2 bg-slate-900 border border-slate-700 rounded-lg">
            <button onclick="addTeacherManual()" class="bg-emerald-600 px-4 rounded-lg font-bold">إضافة</button>
          </div>
          <button onclick="document.getElementById('up-t').click()" class="w-full bg-slate-700 p-2 rounded-lg border border-dashed border-slate-500 mb-4">رفع إكسل معلمين</button>
          <input type="file" id="up-t" class="hidden" onchange="handleT()">
          <div class="max-h-64 overflow-y-auto bg-slate-900 rounded-xl p-2 border border-slate-800">
            <table class="w-full text-right text-sm">
              <thead class="sticky top-0 bg-slate-900"><tr class="text-slate-500 border-b border-slate-800"><th>المعلم</th><th>الكود</th><th>إجراء</th></tr></thead>
              <tbody id="list-t"></tbody>
            </table>
          </div>
        </div>
      </div>
    </section>
    <section id="sec-login" class="hidden max-w-md mx-auto text-center bg-slate-800 p-10 rounded-[2.5rem] border border-slate-700">
      <h2 class="text-2xl font-black mb-6 text-amber-500">دخول المعلمين</h2>
      <input id="auth-code" type="text" placeholder="أدخل الكود" class="w-full p-5 rounded-2xl bg-slate-900 border border-slate-700 text-center text-4xl mb-6 text-white font-black">
      <button onclick="authenticate()" class="w-full bg-amber-500 text-slate-900 py-5 rounded-2xl font-black text-xl">دخول</button>
    </section>
    <section id="sec-control" class="hidden max-w-2xl mx-auto bg-slate-800 p-10 rounded-[3rem] border border-slate-700">
      <h3 id="welcome-txt" class="text-center text-emerald-400 font-black mb-8 text-2xl"></h3>
      <div class="space-y-6">
        <select id="class-filter" onchange="updateList()" class="w-full p-4 rounded-xl bg-slate-900 border border-slate-700 text-white font-bold"></select>
        <select id="student-select" class="w-full p-4 rounded-xl bg-slate-900 border border-slate-700 text-white font-bold"></select>
        <input id="pts" type="text" value="1" class="w-full p-4 rounded-xl bg-slate-900 border border-slate-700 text-center text-5xl font-black text-amber-500">
        <button onclick="addPts()" class="w-full bg-amber-500 text-slate-900 py-6 rounded-2xl font-black text-2xl shadow-xl">إضافة النقاط ✓</button>
      </div>
    </section>
  </main>
  <script>
    function fixNums(str) { return String(str).replace(/[٠-٩]/g, d => '٠١٢٣٤٥٦٧٨٩'.indexOf(d)); }
    let db = { teachers: JSON.parse(localStorage.getItem('walid_t_v9') || '[{"name":"إبراهيم البركاتي","code":"7777"}]'), students: JSON.parse(localStorage.getItem('walid_s_v9') || '[]'), cloudUrl: localStorage.getItem('fb_url_v9') || '', isAuth: false, target: 'control' };
    async function syncPush() { if(!db.cloudUrl) return; try { await fetch(db.cloudUrl + '/data.json', { method: 'PUT', body: JSON.stringify({s: db.students, t: db.teachers}) }); } catch(e){} }
    async function syncPull() { if(!db.cloudUrl) return; try { const res = await fetch(db.cloudUrl + '/data.json'); const data = await res.json(); if(data){ db.students = data.s || []; db.teachers = data.t || []; render(); renderAdminLists(); } } catch(e){} }
    function saveCloudConfig() { db.cloudUrl = document.getElementById('fb-url').value.trim().replace(/\/$/, ""); localStorage.setItem('fb_url_v9', db.cloudUrl); syncPush(); alert("تم الربط!"); }
    function switchTab(t) { if ((t==='control'||t==='admin') && !db.isAuth) { db.target = t; hide(); document.getElementById('sec-login').classList.remove('hidden'); } else { hide(); document.getElementById('sec-' + t).classList.remove('hidden'); if(t==='display') render(); if(t==='control') initC(); if(t==='admin') { document.getElementById('fb-url').value = db.cloudUrl; renderAdminLists(); } } }
    function hide() { ['display','login','control','admin'].forEach(s=>document.getElementById('sec-'+s).classList.add('hidden')); }
    function authenticate() { const c = fixNums(document.getElementById('auth-code').value); const u = db.teachers.find(x=>fixNums(x.code)===c); if(u) { db.isAuth=true; document.getElementById('welcome-txt').innerText = "مرحباً: " + u.name; switchTab(db.target); } else alert('كود خطأ'); }
    function addStudentManual() { const n = document.getElementById('new-s-name').value; const c = document.getElementById('new-s-class').value; if(n && c) { db.students.push({name:n, class:c, points:0}); syncPush(); renderAdminLists(); document.getElementById('new-s-name').value=''; } }
    function addTeacherManual() { const n = document.getElementById('new-t-name').value; if(n) { db.teachers.push({name:n, code:Math.floor(1000+Math.random()*9000).toString()}); syncPush(); renderAdminLists(); document.getElementById('new-t-name').value=''; } }
    function deleteS(idx) { if(confirm('حذف؟')) { db.students.splice(idx,1); syncPush(); renderAdminLists(); } }
    function deleteT(idx) { if(confirm('حذف؟')) { db.teachers.splice(idx,1); syncPush(); renderAdminLists(); } }
    function renderAdminLists() { document.getElementById('list-s').innerHTML = db.students.map((s,i)=>`<tr class="border-b border-slate-800"><td class="p-2">${s.name} (${s.class})</td><td class="p-2"><button onclick="deleteS(${i})" class="btn-delete">حذف</button></td></tr>`).join(''); document.getElementById('list-t').innerHTML = db.teachers.map((t,i)=>`<tr class="border-b border-slate-800"><td class="p-2">${t.name} (كود: ${t.code})</td><td class="p-2"><button onclick="deleteT(${i})" class="btn-delete">حذف</button></td></tr>`).join(''); }
    function render() { const board = document.getElementById('sec-display'); const sorted = [...db.students].sort((a,b)=>b.points-a.points).slice(0,12); board.innerHTML = sorted.map((s,i)=>`<div class="p-8 rounded-[2rem] text-center ${i===0?'gold-card':'bg-slate-800/60 border border-slate-700'}"><div>${i===0?'🥇':i===1?'🥈':i===2?'🥉':'👤'}</div><h3 class="text-xl font-black">${s.name}</h3><p class="text-slate-500 mb-4">${s.class}</p><div class="text-5xl font-black text-amber-500">${s.points}</div></div>`).join(''); }
    function initC() { const cls = [...new Set(db.students.map(s=>s.class))].sort(); document.getElementById('class-filter').innerHTML = '<option value="all">الكل</option>' + cls.map(c=>`<option value="${c}">${c}</option>`).join(''); updateList(); }
    function updateList() { const f = document.getElementById('class-filter').value; const filtered = f==='all'?db.students:db.students.filter(s=>s.class===f); document.getElementById('student-select').innerHTML = filtered.map(s=>`<option value="${db.students.indexOf(s)}">${s.name}</option>`).join(''); }
    async function addPts() { const i = document.getElementById('student-select').value; const p = parseInt(fixNums(document.getElementById('pts').value) || 0); db.students[i].points += p; await syncPush(); alert('تم رصد النقاط!'); render(); }
    setInterval(() => { if(!document.getElementById('sec-display').classList.contains('hidden')) syncPull(); }, 5000);
    function handleT() { const r = new FileReader(); r.onload = (e) => { const json = XLSX.utils.sheet_to_json(XLSX.read(new Uint8Array(e.target.result),{type:'array'}).Sheets[XLSX.read(new Uint8Array(e.target.result),{type:'array'}).SheetNames[0]]); db.teachers = json.map(x=>({name:x.الاسم||x.name, code:Math.floor(1000+Math.random()*9000).toString()})); db.teachers.push({name:"إبراهيم البركاتي", code:"7777"}); syncPush(); renderAdminLists(); alert('تم!'); }; r.readAsArrayBuffer(document.getElementById('up-t').files[0]); }
    function handleS() { const r = new FileReader(); r.onload = (e) => { const json = XLSX.utils.sheet_to_json(XLSX.read(new Uint8Array(e.target.result),{type:'array'}).Sheets[XLSX.read(new Uint8Array(e.target.result),{type:'array'}).SheetNames[0]]); db.students = json.map(x=>({name:x.الاسم||x.name, class:String(x.الفصل||x.class), points:0})); syncPush(); renderAdminLists(); render(); alert('تم!'); }; r.readAsArrayBuffer(document.getElementById('up-s').files[0]); }
    window.onload = render;
  </script>
</body>
</html>
